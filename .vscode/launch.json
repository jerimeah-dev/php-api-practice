{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter iOS Simulator",
      "request": "launch",
      "type": "dart",
      "program": "frontend/lib/main.dart",
      "cwd": "${workspaceFolder}",
      "flutterMode": "debug",
      "deviceId": "apple_ios_simulator",
      "preLaunchTask": "Start PHP Backend"
    },
    {
      "name": "frontend (profile mode)",
      "cwd": "frontend",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "frontend (release mode)",
      "cwd": "frontend",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}
